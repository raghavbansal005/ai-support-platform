PORT=4000
NODE_ENV=development

# SQLite - just a file on disk, nothing to install or run separately.
DATABASE_URL="file:./dev.db"

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Anthropic Claude - used for the RAG chat responses. This is the one paid API this project
# needs; get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxx
ANTHROPIC_MODEL=claude-sonnet-5

# Embeddings run locally via fastembed (ONNX Runtime, CPU) - no API key, no cost, no external
# calls after the model's first download. Options: all-MiniLM-L6-v2 (default, fastest),
# bge-small-en-v1.5, bge-base-en-v1.5 (larger, more accurate, slower).
EMBEDDING_MODEL=all-MiniLM-L6-v2

FRONTEND_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000
MAX_UPLOAD_MB=20
STORAGE_ROOT=./storage
